<!DOCTYPE html>
<html lang="ja">
<head>
  <meta charset="UTF-8">
  <meta name="viewport" content="width=device-width, initial-scale=1.0">
  <title>クリニックM&A 買収金額検討ツール</title>
  <script src="https://cdnjs.cloudflare.com/ajax/libs/pdf.js/3.11.174/pdf.min.js"></script>
  <style>
    *, *::before, *::after { box-sizing: border-box; margin: 0; padding: 0; }

    :root {
      --primary: #1a56db;
      --primary-dark: #1e429f;
      --accent: #0e9f6e;
      --warn: #e3a008;
      --danger: #c81e1e;
      --bg: #f3f4f6;
      --surface: #ffffff;
      --border: #e5e7eb;
      --text: #111827;
      --text-muted: #6b7280;
      --radius: 12px;
      --shadow: 0 1px 3px rgba(0,0,0,.1), 0 1px 2px rgba(0,0,0,.06);
      --shadow-lg: 0 10px 15px -3px rgba(0,0,0,.1), 0 4px 6px -2px rgba(0,0,0,.05);
    }

    body {
      font-family: 'Hiragino Sans', 'Meiryo', sans-serif;
      background: var(--bg);
      color: var(--text);
      min-height: 100vh;
      font-size: 14px;
      line-height: 1.6;
    }

    header {
      background: linear-gradient(135deg, var(--primary-dark) 0%, var(--primary) 100%);
      color: #fff;
      padding: 20px 32px;
      display: flex;
      align-items: center;
      gap: 16px;
      box-shadow: var(--shadow-lg);
    }
    header .icon { font-size: 32px; }
    header h1 { font-size: 22px; font-weight: 700; letter-spacing: .5px; }
    header p { font-size: 12px; opacity: .8; margin-top: 2px; }

    .container { max-width: 1280px; margin: 0 auto; padding: 24px 24px 60px; }

    /* Tabs */
    .tabs { display: flex; gap: 4px; margin-bottom: 24px; background: var(--surface); border-radius: var(--radius); padding: 6px; box-shadow: var(--shadow); }
    .tab-btn {
      flex: 1; padding: 10px 8px; border: none; background: transparent;
      border-radius: 8px; cursor: pointer; font-size: 13px; font-weight: 600;
      color: var(--text-muted); transition: all .2s;
    }
    .tab-btn:hover { background: var(--bg); color: var(--text); }
    .tab-btn.active { background: var(--primary); color: #fff; }

    /* Layout */
    .layout { display: grid; grid-template-columns: 1fr 1fr; gap: 20px; }
    @media (max-width: 900px) { .layout { grid-template-columns: 1fr; } }

    .card {
      background: var(--surface); border-radius: var(--radius);
      box-shadow: var(--shadow); overflow: hidden;
    }
    .card-header {
      padding: 14px 20px;
      display: flex; align-items: center; gap: 10px;
      border-bottom: 1px solid var(--border);
    }
    .card-header .badge {
      display: inline-flex; align-items: center; justify-content: center;
      width: 28px; height: 28px; border-radius: 50%;
      font-size: 12px; font-weight: 700; color: #fff;
    }
    .card-header h2 { font-size: 15px; font-weight: 700; }
    .card-header .subtitle { font-size: 11px; color: var(--text-muted); margin-top: 1px; }
    .card-body { padding: 20px; }

    .badge-blue { background: var(--primary); }
    .badge-green { background: var(--accent); }
    .badge-orange { background: var(--warn); }
    .badge-purple { background: #7c3aed; }

    /* Form elements */
    .field { margin-bottom: 14px; }
    .field label {
      display: block; font-size: 12px; font-weight: 600;
      color: var(--text-muted); margin-bottom: 4px;
    }
    .field .hint { font-size: 11px; color: var(--text-muted); margin-top: 3px; }
    .input-wrap { position: relative; }
    .input-wrap .prefix, .input-wrap .suffix {
      position: absolute; top: 50%; transform: translateY(-50%);
      color: var(--text-muted); font-size: 13px; pointer-events: none;
    }
    .input-wrap .prefix { left: 10px; }
    .input-wrap .suffix { right: 10px; }
    input[type="number"], input[type="text"], select {
      width: 100%; padding: 8px 10px; border: 1px solid var(--border);
      border-radius: 8px; font-size: 13px; color: var(--text);
      background: var(--bg); transition: border-color .2s, box-shadow .2s;
      appearance: none;
    }
    input[type="number"]:focus, select:focus {
      outline: none; border-color: var(--primary);
      box-shadow: 0 0 0 3px rgba(26,86,219,.15);
    }
    .input-wrap.has-prefix input { padding-left: 28px; }
    .input-wrap.has-suffix input { padding-right: 28px; }

    .field-row { display: grid; grid-template-columns: 1fr 1fr; gap: 10px; }

    .section-title {
      font-size: 12px; font-weight: 700; color: var(--text-muted);
      text-transform: uppercase; letter-spacing: .8px;
      margin: 18px 0 10px; border-bottom: 1px solid var(--border); padding-bottom: 6px;
    }

    /* Result boxes */
    .result-box {
      background: linear-gradient(135deg, #eff6ff 0%, #dbeafe 100%);
      border: 1px solid #93c5fd; border-radius: 10px; padding: 16px;
      margin-top: 16px;
    }
    .result-box .label { font-size: 11px; font-weight: 600; color: var(--primary); margin-bottom: 4px; }
    .result-box .amount { font-size: 26px; font-weight: 800; color: var(--primary-dark); }
    .result-box .range { font-size: 12px; color: var(--text-muted); margin-top: 4px; }
    .result-box.green {
      background: linear-gradient(135deg, #ecfdf5 0%, #d1fae5 100%);
      border-color: #6ee7b7;
    }
    .result-box.green .label { color: var(--accent); }
    .result-box.green .amount { color: #065f46; }
    .result-box.orange {
      background: linear-gradient(135deg, #fffbeb 0%, #fef3c7 100%);
      border-color: #fcd34d;
    }
    .result-box.orange .label { color: #92400e; }
    .result-box.orange .amount { color: #78350f; }

    .breakdown { margin-top: 12px; }
    .breakdown-row {
      display: flex; justify-content: space-between; align-items: center;
      padding: 5px 0; border-bottom: 1px dashed var(--border); font-size: 12px;
    }
    .breakdown-row:last-child { border-bottom: none; }
    .breakdown-row .val { font-weight: 600; }
    .breakdown-row .val.neg { color: var(--danger); }
    .breakdown-row .val.pos { color: var(--accent); }
    .breakdown-row.total {
      font-weight: 700; border-top: 2px solid var(--border);
      border-bottom: none; margin-top: 4px; padding-top: 8px; font-size: 13px;
    }

    /* Summary panel */
    .summary-card { grid-column: 1 / -1; }
    .summary-grid { display: grid; grid-template-columns: repeat(3, 1fr); gap: 16px; margin-bottom: 20px; }
    @media (max-width: 700px) { .summary-grid { grid-template-columns: 1fr; } }
    .summary-item {
      background: var(--bg); border-radius: 10px; padding: 16px;
      text-align: center; border: 2px solid transparent; transition: border-color .2s;
    }
    .summary-item.highlight { border-color: var(--primary); }
    .summary-item .method { font-size: 11px; font-weight: 700; color: var(--text-muted); margin-bottom: 6px; }
    .summary-item .val { font-size: 22px; font-weight: 800; }
    .summary-item .sub { font-size: 11px; color: var(--text-muted); margin-top: 3px; }

    .recommendation-box {
      background: #f0fdf4; border: 1px solid #bbf7d0;
      border-radius: 10px; padding: 16px; margin-top: 4px;
    }
    .recommendation-box h3 { font-size: 13px; font-weight: 700; color: #166534; margin-bottom: 8px; }
    .recommendation-box p { font-size: 12px; color: #166534; line-height: 1.7; }

    .chart-wrap { height: 180px; position: relative; margin: 16px 0; }
    .bar-chart { display: flex; align-items: flex-end; gap: 16px; height: 100%; }
    .bar-group { flex: 1; display: flex; flex-direction: column; align-items: center; gap: 4px; }
    .bar-outer { width: 100%; flex: 1; display: flex; align-items: flex-end; }
    .bar {
      width: 100%; border-radius: 6px 6px 0 0; position: relative;
      transition: height .5s ease; min-height: 4px;
    }
    .bar-label { font-size: 11px; font-weight: 600; color: var(--text-muted); text-align: center; }
    .bar-val { font-size: 12px; font-weight: 700; text-align: center; }

    /* DCF table */
    .dcf-table { width: 100%; border-collapse: collapse; font-size: 12px; margin-top: 10px; }
    .dcf-table th {
      background: var(--primary); color: #fff; padding: 7px 8px;
      text-align: right; font-weight: 600;
    }
    .dcf-table th:first-child { text-align: left; }
    .dcf-table td {
      padding: 6px 8px; border-bottom: 1px solid var(--border);
      text-align: right;
    }
    .dcf-table td:first-child { text-align: left; font-weight: 600; color: var(--text-muted); }
    .dcf-table tr:nth-child(even) { background: var(--bg); }
    .dcf-table tr.total-row td {
      background: #dbeafe; font-weight: 700;
      color: var(--primary-dark); border-top: 2px solid var(--primary);
    }

    /* Range slider */
    input[type="range"] {
      -webkit-appearance: none; appearance: none;
      width: 100%; height: 6px; background: var(--border);
      border-radius: 3px; outline: none; cursor: pointer;
    }
    input[type="range"]::-webkit-slider-thumb {
      -webkit-appearance: none; appearance: none;
      width: 18px; height: 18px; background: var(--primary);
      border-radius: 50%; cursor: pointer; border: 2px solid #fff;
      box-shadow: 0 0 0 2px var(--primary);
    }
    .slider-labels { display: flex; justify-content: space-between; font-size: 10px; color: var(--text-muted); margin-top: 4px; }

    .tag {
      display: inline-block; padding: 2px 8px; border-radius: 20px;
      font-size: 10px; font-weight: 700;
    }
    .tag-blue { background: #dbeafe; color: var(--primary); }
    .tag-green { background: #d1fae5; color: #065f46; }
    .tag-orange { background: #fef3c7; color: #92400e; }

    .btn {
      padding: 10px 20px; border: none; border-radius: 8px;
      font-size: 13px; font-weight: 700; cursor: pointer; transition: all .2s;
    }
    .btn-primary { background: var(--primary); color: #fff; }
    .btn-primary:hover { background: var(--primary-dark); }
    .btn-outline { background: transparent; border: 1px solid var(--border); color: var(--text); }
    .btn-outline:hover { background: var(--bg); }
    .btn-row { display: flex; gap: 10px; justify-content: flex-end; margin-top: 16px; }

    .panel { display: none; }
    .panel.active { display: block; }

    .info-callout {
      background: #eff6ff; border-left: 3px solid var(--primary);
      border-radius: 0 8px 8px 0; padding: 10px 14px; font-size: 12px;
      color: #1e40af; margin-bottom: 14px; line-height: 1.6;
    }

    .multiple-table { width: 100%; border-collapse: collapse; font-size: 12px; margin: 10px 0; }
    .multiple-table th { background: var(--bg); padding: 7px 10px; text-align: left; font-weight: 700; border-bottom: 2px solid var(--border); }
    .multiple-table td { padding: 6px 10px; border-bottom: 1px solid var(--border); }
    .multiple-table .highlight-row { background: #eff6ff; font-weight: 700; }

    /* ── Upload Modal ── */
    .modal-overlay {
      display: none; position: fixed; inset: 0;
      background: rgba(0,0,0,.55); z-index: 1000;
      align-items: center; justify-content: center;
    }
    .modal-overlay.open { display: flex; }
    .modal {
      background: #fff; border-radius: 16px; width: 780px; max-width: 96vw;
      max-height: 90vh; display: flex; flex-direction: column;
      box-shadow: 0 25px 50px rgba(0,0,0,.25); overflow: hidden;
    }
    .modal-header {
      padding: 18px 24px; background: linear-gradient(135deg,#1e3a8a,#1d4ed8);
      color: #fff; display: flex; align-items: center; gap: 12px;
      flex-shrink: 0;
    }
    .modal-header h2 { font-size: 16px; font-weight: 700; flex: 1; }
    .modal-close {
      background: rgba(255,255,255,.2); border: none; color: #fff;
      width: 32px; height: 32px; border-radius: 50%; font-size: 18px;
      cursor: pointer; display: flex; align-items: center; justify-content: center;
      transition: background .2s;
    }
    .modal-close:hover { background: rgba(255,255,255,.35); }
    .modal-body { padding: 24px; overflow-y: auto; flex: 1; }
    .modal-footer {
      padding: 16px 24px; border-top: 1px solid var(--border);
      display: flex; gap: 10px; justify-content: flex-end; flex-shrink: 0;
      background: var(--bg);
    }

    /* Drop zone */
    .drop-zone {
      border: 2px dashed #93c5fd; border-radius: 12px;
      padding: 32px 20px; text-align: center; cursor: pointer;
      background: #eff6ff; transition: all .2s; margin-bottom: 20px;
    }
    .drop-zone:hover, .drop-zone.drag-over {
      border-color: var(--primary); background: #dbeafe;
    }
    .drop-zone .dz-icon { font-size: 40px; margin-bottom: 8px; }
    .drop-zone .dz-title { font-size: 15px; font-weight: 700; color: var(--primary); margin-bottom: 4px; }
    .drop-zone .dz-sub { font-size: 12px; color: var(--text-muted); }
    #file-input { display: none; }

    /* Unit selector */
    .unit-row {
      display: flex; align-items: center; gap: 12px;
      background: #fef3c7; border-radius: 8px; padding: 10px 14px;
      margin-bottom: 16px; font-size: 12px;
    }
    .unit-row label { font-weight: 700; color: #92400e; white-space: nowrap; }
    .unit-row select {
      padding: 4px 8px; border-radius: 6px; border: 1px solid #fcd34d;
      background: #fff; font-size: 12px; color: var(--text);
    }
    .unit-row .unit-note { color: #92400e; flex: 1; }

    /* Progress */
    .progress-bar-wrap {
      display: none; background: var(--border); border-radius: 4px;
      height: 6px; margin-bottom: 12px; overflow: hidden;
    }
    .progress-bar-fill {
      height: 100%; background: var(--primary);
      border-radius: 4px; transition: width .3s;
    }
    .progress-msg { font-size: 12px; color: var(--text-muted); margin-bottom: 16px; text-align: center; }

    /* Extraction table */
    .extract-table { width: 100%; border-collapse: collapse; font-size: 12px; }
    .extract-table th {
      background: var(--primary); color: #fff; padding: 8px 10px;
      text-align: left; font-weight: 600; position: sticky; top: 0; z-index: 1;
    }
    .extract-table th:last-child { text-align: center; width: 50px; }
    .extract-table td { padding: 7px 10px; border-bottom: 1px solid var(--border); vertical-align: middle; }
    .extract-table tr:nth-child(even) { background: var(--bg); }
    .extract-table tr.not-found td { opacity: .55; }
    .found-badge {
      display: inline-block; padding: 2px 7px; border-radius: 10px;
      font-size: 10px; font-weight: 700;
    }
    .found-badge.ok  { background: #d1fae5; color: #065f46; }
    .found-badge.ng  { background: #fee2e2; color: #991b1b; }
    .extract-table .val-input {
      width: 110px; padding: 4px 6px; border: 1px solid var(--border);
      border-radius: 6px; font-size: 12px; text-align: right;
      background: #fff;
    }
    .extract-table .val-input:focus {
      outline: none; border-color: var(--primary);
      box-shadow: 0 0 0 2px rgba(26,86,219,.15);
    }
    .extract-table .targets { color: var(--text-muted); font-size: 10px; }

    /* Paste tab */
    .upload-tabs { display: flex; gap: 4px; margin-bottom: 16px; }
    .upload-tab-btn {
      padding: 8px 14px; border: 1px solid var(--border); background: var(--bg);
      border-radius: 8px; cursor: pointer; font-size: 12px; font-weight: 600;
      color: var(--text-muted); transition: all .2s;
    }
    .upload-tab-btn.active { background: var(--primary); color: #fff; border-color: var(--primary); }
    .upload-panel { display: none; }
    .upload-panel.active { display: block; }
    #paste-area {
      width: 100%; height: 140px; border: 1px solid var(--border);
      border-radius: 8px; padding: 10px; font-size: 12px; font-family: monospace;
      resize: vertical; background: var(--bg);
    }
    #paste-area:focus { outline: none; border-color: var(--primary); }

    /* Header upload btn */
    .header-upload-btn {
      margin-left: auto; padding: 8px 16px;
      background: rgba(255,255,255,.2); border: 1px solid rgba(255,255,255,.4);
      color: #fff; border-radius: 8px; cursor: pointer;
      font-size: 13px; font-weight: 700; transition: all .2s;
      display: flex; align-items: center; gap: 6px;
    }
    .header-upload-btn:hover { background: rgba(255,255,255,.35); }

    .apply-count {
      display: inline-block; background: #fbbf24; color: #78350f;
      border-radius: 10px; padding: 1px 7px; font-size: 11px;
      font-weight: 700; margin-left: 4px;
    }
    .cand-select {
      display: block; margin-top: 4px; width: 100%; max-width: 200px;
      padding: 3px 6px; border: 1px solid #93c5fd; border-radius: 5px;
      font-size: 11px; background: #eff6ff; color: #1e40af; cursor: pointer;
    }
    .cand-select:focus { outline: none; border-color: var(--primary); }

    @keyframes fadeInDown {
      from { opacity: 0; transform: translateX(-50%) translateY(-10px); }
      to   { opacity: 1; transform: translateX(-50%) translateY(0); }
    }

    /* ── BS section headers ── */
    .bs-section {
      border-radius: 8px; margin: 14px 0 8px; padding: 6px 12px;
      font-size: 12px; font-weight: 700; display: flex; align-items: center; gap: 6px;
    }
    .bs-section.asset  { background: #eff6ff; color: #1e40af; border-left: 3px solid var(--primary); }
    .bs-section.liab   { background: #fff1f2; color: #9f1239; border-left: 3px solid #e11d48; }
    .bs-section.adjust { background: #f0fdf4; color: #065f46; border-left: 3px solid var(--accent); }
    .linked-display {
      background: #eff6ff; border: 1px solid #93c5fd; border-radius: 8px;
      padding: 10px 14px; margin-bottom: 14px;
    }
    .linked-display .ld-grid {
      display: grid; grid-template-columns: repeat(3,1fr); gap: 10px;
    }
    .linked-display .ld-item .ld-label {
      font-size: 10px; color: #3b82f6; margin-bottom: 2px; font-weight:600;
    }
    .linked-display .ld-item .ld-val {
      font-size: 17px; font-weight: 800; color: #1e3a8a;
    }
    .linked-display .ld-note {
      font-size: 10px; color: #3b82f6; margin-top: 8px; opacity: .8;
    }

    /* ── Save/Load Modal ── */
    .header-save-btn {
      padding: 8px 16px;
      background: rgba(255,255,255,.15); border: 1px solid rgba(255,255,255,.4);
      color: #fff; border-radius: 8px; cursor: pointer;
      font-size: 13px; font-weight: 700; transition: all .2s;
      display: flex; align-items: center; gap: 6px;
    }
    .header-save-btn:hover { background: rgba(255,255,255,.3); }

    .save-tabs { display: flex; gap: 4px; margin-bottom: 18px; }
    .save-tab-btn {
      flex: 1; padding: 9px 8px; border: 1px solid var(--border);
      background: var(--bg); border-radius: 8px; cursor: pointer;
      font-size: 13px; font-weight: 600; color: var(--text-muted); transition: all .2s;
    }
    .save-tab-btn.active { background: var(--primary); color: #fff; border-color: var(--primary); }
    .save-panel { display: none; }
    .save-panel.active { display: block; }

    .save-name-row {
      display: flex; gap: 8px; margin-bottom: 14px; align-items: center;
    }
    .save-name-row input {
      flex: 1; padding: 9px 12px; border: 1px solid var(--border);
      border-radius: 8px; font-size: 13px; background: var(--bg);
    }
    .save-name-row input:focus {
      outline: none; border-color: var(--primary);
      box-shadow: 0 0 0 3px rgba(26,86,219,.15);
    }

    .save-list { display: flex; flex-direction: column; gap: 8px; max-height: 340px; overflow-y: auto; }
    .save-item {
      display: flex; align-items: center; gap: 10px;
      background: var(--bg); border: 1px solid var(--border);
      border-radius: 10px; padding: 12px 14px; cursor: pointer;
      transition: all .2s;
    }
    .save-item:hover { border-color: var(--primary); background: #eff6ff; }
    .save-item .si-icon { font-size: 20px; }
    .save-item .si-info { flex: 1; min-width: 0; }
    .save-item .si-name { font-size: 13px; font-weight: 700; color: var(--text); white-space: nowrap; overflow: hidden; text-overflow: ellipsis; }
    .save-item .si-date { font-size: 11px; color: var(--text-muted); margin-top: 2px; }
    .save-item .si-preview { font-size: 11px; color: #1e40af; margin-top: 3px; }
    .save-item .si-del {
      background: #fee2e2; border: none; color: #991b1b;
      border-radius: 6px; padding: 4px 8px; font-size: 11px;
      font-weight: 700; cursor: pointer; white-space: nowrap;
      transition: background .2s; flex-shrink: 0;
    }
    .save-item .si-del:hover { background: #fca5a5; }
    .save-empty {
      text-align: center; padding: 40px 20px;
      color: var(--text-muted); font-size: 13px;
    }
    .save-empty .se-icon { font-size: 40px; margin-bottom: 8px; }

    .io-row { display: flex; gap: 10px; margin-top: 16px; }
    .io-row .btn { flex: 1; display: flex; align-items: center; justify-content: center; gap: 6px; }
  </style>
</head>
<body>
<header>
  <div class="icon">🏥</div>
  <div>
    <h1>クリニック M&A 買収金額検討ツール</h1>
    <p>マルチプル法・純資産法・DCF法による企業価値評価</p>
  </div>
  <button class="header-save-btn" onclick="openSaveModal()">
    💾 保存・読込
  </button>
  <button class="header-upload-btn" onclick="openUploadModal()">
    📄 決算書を読み込む
  </button>
</header>

<!-- ===== SAVE / LOAD MODAL ===== -->
<div class="modal-overlay" id="save-modal">
  <div class="modal" style="width:600px;">
    <div class="modal-header" style="background:linear-gradient(135deg,#064e3b,#059669);">
      <span style="font-size:22px;">💾</span>
      <h2>データ保存・読込</h2>
      <button class="modal-close" onclick="closeSaveModal()">✕</button>
    </div>
    <div class="modal-body">

      <div class="save-tabs">
        <button class="save-tab-btn active" onclick="switchSaveTab('save')">💾 保存</button>
        <button class="save-tab-btn" onclick="switchSaveTab('load')">📂 読込</button>
