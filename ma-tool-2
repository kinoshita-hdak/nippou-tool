            <div style="font-size:20px; font-weight:800; color:#065f46;" id="sum_netdebt_disp">— 万円</div>
            <div style="font-size:10px; color:var(--text-muted); margin-top:2px;" id="sum_netdebt_sub">借入金 − 現預金</div>
          </div>
          <div style="background:#fdf4ff; border-radius:10px; padding:12px 14px; border-left:3px solid #a855f7;">
            <div style="font-size:10px; font-weight:700; color:#a855f7; margin-bottom:4px;">📊 EV/EBITDA（参考）</div>
            <div style="font-size:20px; font-weight:800; color:#581c87;" id="sum_ev_ebitda_disp">— 倍</div>
            <div style="font-size:10px; color:var(--text-muted); margin-top:2px;">加重平均EV ÷ EBITDA</div>
          </div>
        </div>

        <!-- ── 3手法比較 ── -->
        <div class="summary-grid">
          <div class="summary-item" id="sum_multiple">
            <div class="method">📊 マルチプル法</div>
            <div class="val" id="sum_m_val" style="color:var(--primary)">— 万円</div>
            <div class="sub" id="sum_m_sub">（EBITDA / 売上倍率）</div>
          </div>
          <div class="summary-item" id="sum_netasset">
            <div class="method">🏦 純資産法</div>
            <div class="val" id="sum_n_val" style="color:var(--accent)">— 万円</div>
            <div class="sub">（修正純資産）</div>
          </div>
          <div class="summary-item" id="sum_dcf">
            <div class="method">📈 DCF法</div>
            <div class="val" id="sum_d_val" style="color:var(--warn)">— 万円</div>
            <div class="sub">（将来CF割引）</div>
          </div>
        </div>

        <div class="chart-wrap">
          <div class="bar-chart" id="sum_chart"></div>
        </div>

        <div style="background:var(--bg); border-radius:10px; padding:16px; margin-bottom:16px;">
          <div style="font-size:12px; font-weight:700; color:var(--text-muted); margin-bottom:10px;">ウェイト設定（合計100%）</div>
          <div class="field-row" style="gap:16px; align-items:center;">
            <div class="field" style="margin:0">
              <label>マルチプル法 <span id="w_m_val">40</span>%</label>
              <input type="range" id="w_m" min="0" max="100" value="40" oninput="updateWeights('w_m')">
            </div>
            <div class="field" style="margin:0">
              <label>純資産法 <span id="w_n_val">20</span>%</label>
              <input type="range" id="w_n" min="0" max="100" value="20" oninput="updateWeights('w_n')">
            </div>
            <div class="field" style="margin:0">
              <label>DCF法 <span id="w_d_val">40</span>%</label>
              <input type="range" id="w_d" min="0" max="100" value="40" oninput="updateWeights('w_d')">
            </div>
          </div>
        </div>

        <div style="display:flex; gap:16px; align-items:stretch; flex-wrap:wrap;">
          <div style="flex:1; min-width:220px; background:linear-gradient(135deg,#1e3a8a,#1d4ed8); border-radius:12px; padding:20px; color:#fff;">
            <div style="font-size:12px; opacity:.8; margin-bottom:6px;">加重平均 買収価格目安</div>
            <div style="font-size:32px; font-weight:800;" id="sum_weighted">— 万円</div>
            <div style="font-size:11px; opacity:.7; margin-top:4px;">3手法の加重平均値</div>
          </div>
          <div style="flex:1; min-width:220px; background:linear-gradient(135deg,#064e3b,#059669); border-radius:12px; padding:20px; color:#fff;">
            <div style="font-size:12px; opacity:.8; margin-bottom:6px;">推奨交渉レンジ</div>
            <div style="font-size:22px; font-weight:800;" id="sum_range">— 〜 — 万円</div>
            <div style="font-size:11px; opacity:.7; margin-top:4px;">加重平均 ±15%</div>
          </div>
        </div>

        <div class="recommendation-box" style="margin-top:16px;">
          <h3>💡 クリニックM&A 評価ポイント</h3>
          <p id="sum_recommendation">各手法の数値を入力すると、ここに評価コメントが表示されます。</p>
        </div>
      </div>
    </div>
  </div>
</div>

<script>
// ─── State ───────────────────────────────────────────────────
const state = {
  multiple: { ebitda: 0, rev: 0, range: [0, 0] },
  netasset: { value: 0 },
  dcf:      { value: 0 }
};

// ─── Utilities ───────────────────────────────────────────────
const $ = id => document.getElementById(id);
const fmt = n => {
  if (isNaN(n) || n === null) return '—';
  return Math.round(n).toLocaleString('ja-JP') + ' 万円';
};
const fmtNum = n => isNaN(n) ? '—' : Math.round(n).toLocaleString('ja-JP');
const val = id => parseFloat($(id).value) || 0;

function updateSlider(sliderId, labelId) {
  $(labelId).textContent = parseFloat($(sliderId).value).toFixed(1);
}

function showTab(name) {
  ['multiple', 'netasset', 'dcf', 'summary'].forEach(t => {
    $('tab-' + t).classList.toggle('active', t === name);
  });
  document.querySelectorAll('.tab-btn').forEach((btn, i) => {
    btn.classList.remove('active');
  });
  const tabs = ['multiple', 'netasset', 'dcf', 'summary'];
  document.querySelectorAll('.tab-btn')[tabs.indexOf(name)].classList.add('active');
  if (name === 'summary') updateSummary();
}

// ─── 循環参照防止フラグ ───────────────────────────────────────
let _recalcInProgress = false;

// ─── Multiple Method ─────────────────────────────────────────
function calcMultiple() {
  const revenue     = val('m_revenue');
  const ebit        = val('m_ebit');
  const da          = val('m_da');
  const execCurrent = val('m_exec_current');
  const execNew     = val('m_exec_new');
  // 純有利子負債 = (短期借入金 + 長期借入金) − 現預金（純資産法タブから自動取得）
  const debt        = (val('n_short_loan') + val('n_long_loan')) - val('n_cash');
  const ebitdaMult  = val('m_ebitda_mult');
  const revMult     = val('m_rev_mult');

  // 調整EBITDA = 営業利益 + 減価償却費 + 現役員報酬 − 新役員報酬
  const ebitda = ebit + da + execCurrent - execNew;
  const ev1    = ebitda * ebitdaMult;
  const eq1    = ev1 - debt;
  const ev2    = revenue * revMult;
  const eq2    = ev2 - debt;

  // 純有利子負債の自動表示更新
  const debtLabel = debt < 0
    ? `${fmtNum(Math.abs(Math.round(debt)))} 万円（ネットキャッシュ）`
    : fmt(debt);
  if ($('m_debt_auto_disp')) $('m_debt_auto_disp').textContent = debtLabel;

  $('m_ebit_disp').textContent         = fmt(ebit);
  $('m_da_disp').textContent           = '＋ ' + fmtNum(da) + ' 万円';
  $('m_exec_current_disp').textContent = '＋ ' + fmtNum(execCurrent) + ' 万円';
  $('m_exec_new_disp').textContent     = '− ' + fmtNum(execNew) + ' 万円';
  $('m_ebitda_disp').textContent       = fmt(ebitda);
  $('m_mult1_disp').textContent        = ebitdaMult.toFixed(1) + ' 倍';
  $('m_ev1_disp').textContent          = fmt(ev1);
  $('m_debt1_disp').textContent        = fmt(debt);
  $('m_equity1_disp').textContent      = fmt(eq1);
  $('m_result_ebitda').textContent     = fmt(eq1);

  $('m_rev_disp').textContent      = fmt(revenue);
  $('m_mult2_disp').textContent    = revMult.toFixed(1) + ' 倍';
  $('m_ev2_disp').textContent      = fmt(ev2);
  $('m_debt2_disp').textContent    = fmt(debt);
  $('m_equity2_disp').textContent  = fmt(eq2);
  $('m_result_rev').textContent    = fmt(eq2);

  const lo = Math.min(eq1, eq2);
  const hi = Math.max(eq1, eq2);
  $('m_range_disp').textContent = `${fmtNum(lo)} 〜 ${fmtNum(hi)} 万円`;

  state.multiple = { ebitda: eq1, rev: eq2, range: [lo, hi], adjustedEbitda: ebitda };

  // 純資産法ののれんを再計算（EBITDA連動）
  calcNetAsset();

  // 総合評価タブが開いているときはリアルタイム更新
  if ($('tab-summary').classList.contains('active')) updateSummary();
}

// ─── Net Asset Method ────────────────────────────────────────
function calcNetAsset() {
  // ── 資産 ──
  const cash         = val('n_cash');
  const ar           = val('n_ar');
  const inventory    = val('n_inventory');
  const otherCurrent = val('n_other_current');
  const equipment    = val('n_equipment');
  const interior     = val('n_interior');
  const lease        = val('n_lease');
  const deposit      = val('n_deposit');
  const otherFixed   = val('n_other_asset');
  // ── 負債 ──
  const shortLoan    = val('n_short_loan');
  const ap           = val('n_ap');
  const accrued      = val('n_accrued');
  const otherCurLiab = val('n_other_current_liab');
  const longLoan     = val('n_long_loan');
  const leaseLiab    = val('n_lease_liab');
  const otherFixLiab = val('n_other_liab');
  // ── 調整 ──
  const equipAdj  = val('n_equip_adj');
  const gwMult    = val('n_gw_mult');

  // のれん = 調整EBITDA（マルチプル法より） × のれん倍率
  const adjEbitda = state.multiple.adjustedEbitda || 0;
  const goodwill  = adjEbitda * gwMult;

  const totalAsset = cash + ar + inventory + otherCurrent
                   + equipment + interior + lease + deposit + otherFixed;
  const totalLiab  = shortLoan + ap + accrued + otherCurLiab
                   + longLoan + leaseLiab + otherFixLiab;
  const bookNet    = totalAsset - totalLiab;
  const adjNet     = bookNet + equipAdj + goodwill;

  // 入力パネルの参照表示更新
  $('n_ref_ebitda').textContent      = fmt(adjEbitda);
  $('n_gw_mult_disp2').textContent   = gwMult.toFixed(1);
  $('n_goodwill_calc').textContent   = fmt(goodwill);

  // 結果パネル ── 資産
  $('n_cash_disp').textContent            = fmt(cash);
  $('n_ar_disp').textContent              = fmt(ar);
  $('n_inventory_disp').textContent       = fmt(inventory);
  $('n_other_current_disp').textContent   = fmt(otherCurrent);
  $('n_equip_disp').textContent           = fmt(equipment);
  $('n_interior_disp').textContent        = fmt(interior);
  $('n_lease_disp').textContent           = fmt(lease);
  $('n_deposit_disp').textContent         = fmt(deposit);
  $('n_other_asset_disp').textContent     = fmt(otherFixed);
  $('n_total_asset_disp').textContent     = fmt(totalAsset);

  // 結果パネル ── 負債
  const neg = v => '▲ ' + fmtNum(v) + ' 万円';
  $('n_short_loan_disp').textContent      = neg(shortLoan);
  $('n_ap_disp').textContent              = neg(ap);
  $('n_accrued_disp').textContent         = neg(accrued);
  $('n_other_current_liab_disp').textContent = neg(otherCurLiab);
  $('n_long_loan_disp').textContent       = neg(longLoan);
  $('n_lease_liab_disp').textContent      = neg(leaseLiab);
  $('n_other_liab_disp').textContent      = neg(otherFixLiab);
  $('n_total_liab_disp').textContent      = '▲ ' + fmtNum(totalLiab) + ' 万円';

  // 結果パネル ── 評価調整
  $('n_book_net_disp').textContent    = fmt(bookNet);
  $('n_equip_adj_disp').textContent   = (equipAdj >= 0 ? '+' : '') + fmtNum(equipAdj) + ' 万円';
  $('n_goodwill_disp').textContent    = `+${fmtNum(Math.round(goodwill))} 万円（${gwMult.toFixed(1)}× EBITDA ${fmtNum(Math.round(adjEbitda))}万円）`;
  $('n_total_disp').textContent       = fmt(adjNet);
  $('n_result').textContent           = fmt(adjNet);
  $('n_result_sub').textContent       = `簿価純資産 ${fmtNum(Math.round(bookNet))} ＋ のれん ${fmtNum(Math.round(goodwill))} ＋ 機器修正 ${fmtNum(equipAdj)} 万円`;

  state.netasset = { value: adjNet };

  // 純資産法の入力（n_loan/n_cash）が変わったとき、マルチプル法とDCF法も更新
  // 循環参照（calcMultiple→calcNetAsset→calcMultiple）を防止するガードフラグ
  if (!_recalcInProgress) {
    _recalcInProgress = true;
    calcMultiple(); // 内部でcalcNetAssetを呼ぶがフラグにより無限ループしない
    calcDCF();
    _recalcInProgress = false;
  }
}

// ─── DCF Method ──────────────────────────────────────────────
function calcDCF() {
  // ★ 売上・営業利益・減価償却はマルチプル法タブと連動
  const revenue = val('m_revenue');
  const ebit    = val('m_ebit');
  const da      = val('m_da');
  const taxRate = val('d_tax') / 100;
  const capex   = val('d_capex');
  const wc      = val('d_wc');
  const growth  = val('d_growth') / 100;
  const wacc    = val('d_wacc') / 100;
  const gTerm   = val('d_terminal') / 100;
  // 純有利子負債 = (短期借入金 + 長期借入金) − 現預金（純資産法タブから自動取得）
  const debt    = (val('n_short_loan') + val('n_long_loan')) - val('n_cash');
  const years   = parseInt($('d_years').value);

  // マルチプル法連動値の表示更新
  if ($('d_revenue_linked')) $('d_revenue_linked').textContent = fmt(revenue);
  if ($('d_ebit_linked'))    $('d_ebit_linked').textContent    = fmt(ebit);
  if ($('d_da_linked'))      $('d_da_linked').textContent      = fmt(da);

  // DCF法タブの純有利子負債自動表示更新
  const debtLabelD = debt < 0
    ? `${fmtNum(Math.abs(Math.round(debt)))} 万円（ネットキャッシュ）`
    : fmt(debt);
  if ($('d_debt_auto_disp')) $('d_debt_auto_disp').textContent = debtLabelD;

  // ベースFCF算出（決算書より）
  // FCF = 営業利益 × (1 - 税率) + 減価償却費 - 設備投資 - 運転資本増加額
  const nopat   = ebit * (1 - taxRate);
  const baseFCF = nopat + da - capex - wc;

  // ベースFCF内訳表示
  $('d_ebit_disp').textContent     = fmt(ebit);
  $('d_tax_disp').textContent      = `(1 − ${(taxRate*100).toFixed(1)}%) = ${(1-taxRate).toFixed(3)}`;
  $('d_nopat_disp').textContent    = fmt(nopat);
  $('d_da_disp').textContent       = '＋ ' + fmtNum(da) + ' 万円';
  $('d_capex_disp').textContent    = '− ' + fmtNum(capex) + ' 万円';
  $('d_wc_disp').textContent       = '− ' + fmtNum(wc) + ' 万円';
  $('d_base_fcf_disp').textContent = fmt(baseFCF);

  // テーブルヘッダー更新
  const thead = document.querySelector('#dcf_table thead tr');
  thead.innerHTML = '<th>項目</th>' + Array.from({length: years}, (_, i) => `<th>Year ${i+1}</th>`).join('');

  // 将来FCF予測（ベースFCFに成長率を適用）
  let pvSum = 0;
  const fcfs = [], pvs = [], discounts = [];

  for (let y = 1; y <= years; y++) {
    const fcf      = baseFCF * Math.pow(1 + growth, y);
    const discount = 1 / Math.pow(1 + wacc, y);
    const pv       = fcf * discount;
    fcfs.push(fcf);
    discounts.push(discount);
    pvs.push(pv);
    pvSum += pv;
  }

  // ターミナルバリュー（ゴードン成長モデル）
  const lastFCF = fcfs[years - 1];
  const tv      = (wacc - gTerm) !== 0 ? lastFCF * (1 + gTerm) / (wacc - gTerm) : 0;
  const pvTV    = tv / Math.pow(1 + wacc, years);
  const ev      = pvSum + pvTV;
  const equity  = ev - debt;

  // テーブル描画
  const tbody = $('dcf_tbody');
  tbody.innerHTML = [
    buildRow('FCF（万円）',     fcfs),
    buildRow('割引係数',        discounts, true),
    buildRow('FCF現在価値（万円）', pvs),
  ].join('') + `<tr class="total-row"><td>累計 PV（FCF）</td><td colspan="${years}" style="text-align:right;">${fmtNum(Math.round(pvSum))} 万円</td></tr>`;

  $('d_pv_fcf_disp').textContent = fmt(pvSum);
  $('d_tv_disp').textContent     = fmt(tv);
  $('d_pv_tv_disp').textContent  = fmt(pvTV);
  $('d_ev_disp').textContent     = fmt(ev);
  $('d_debt_disp').textContent   = fmt(debt);
  $('d_equity_disp').textContent = fmt(equity);
  $('d_result').textContent      = fmt(equity);
  $('d_tv_ratio').textContent    = ev > 0 ? `TV比率: ${Math.round(pvTV/ev*100)}%　ベースFCF: ${fmtNum(Math.round(baseFCF))} 万円` : '';

  state.dcf = { value: equity };

  // 総合評価タブが開いているときはリアルタイム更新
  if ($('tab-summary').classList.contains('active')) updateSummary();
}

function buildRow(label, values, isRatio) {
  const cells = values.map(v => `<td>${isRatio ? v.toFixed(3) : fmtNum(Math.round(v))}</td>`).join('');
  return `<tr><td>${label}</td>${cells}</tr>`;
}

// ─── Summary ─────────────────────────────────────────────────
function updateSummary() {
  const m = (state.multiple.ebitda + state.multiple.rev) / 2;
  const n = state.netasset.value;
  const d = state.dcf.value;

  const wm = val('w_m') / 100;
  const wn = val('w_n') / 100;
  const wd = val('w_d') / 100;
  const wTotal = wm + wn + wd;

  $('sum_m_val').textContent = fmt(m);
  $('sum_n_val').textContent = fmt(n);
  $('sum_d_val').textContent = fmt(d);

  const weighted = wTotal > 0 ? (m * wm + n * wn + d * wd) / wTotal : (m + n + d) / 3;
  $('sum_weighted').textContent = fmt(weighted);
  $('sum_range').textContent = `${fmtNum(Math.round(weighted * 0.85))} 〜 ${fmtNum(Math.round(weighted * 1.15))} 万円`;

  // ── 財務指標サマリー更新 ──────────────────────────────────
  const ebitda  = state.multiple.adjustedEbitda || 0;
  const revenue = val('m_revenue');
  const netDebt = (val('n_short_loan') + val('n_long_loan')) - val('n_cash');

  // 調整EBITDA
  $('sum_ebitda_disp').textContent  = fmt(ebitda);
  const margin = revenue > 0 ? Math.round(ebitda / revenue * 100) : 0;
  $('sum_ebitda_margin').textContent = `EBITDA率 ${margin}%（売上 ${fmtNum(revenue)}万円）`;

  // 売上高
  $('sum_revenue_disp').textContent = fmt(revenue);

  // 純有利子負債 / ネットキャッシュ
  const isNetCash = netDebt < 0;
  $('sum_netdebt_label').textContent = isNetCash ? '💰 ネットキャッシュ' : '🏦 純有利子負債';
  $('sum_netdebt_disp').textContent  = isNetCash
    ? `+${fmtNum(Math.abs(Math.round(netDebt)))} 万円`
    : fmt(netDebt);
  $('sum_netdebt_sub').textContent   = isNetCash
    ? '現預金 > 借入金（財務良好）'
    : `借入金 ${fmtNum(val('n_short_loan')+val('n_long_loan'))}万 − 現預金 ${fmtNum(val('n_cash'))}万`;
  $('sum_netdebt_card').style.background = isNetCash ? '#ecfdf5' : '#fef2f2';
  $('sum_netdebt_card').style.borderLeftColor = isNetCash ? '#10b981' : '#ef4444';
  $('sum_netdebt_label').style.color  = isNetCash ? '#059669' : '#dc2626';
  $('sum_netdebt_disp').style.color   = isNetCash ? '#065f46' : '#7f1d1d';

  // EV/EBITDA参考倍率（加重平均EV ÷ 調整EBITDA）
  // EV = 株式価値 + 純有利子負債
  const avgEquity = weighted;
  const avgEV     = avgEquity + netDebt;
  const evEbitda  = (ebitda > 0 && avgEV > 0) ? (avgEV / ebitda).toFixed(1) : '—';
  $('sum_ev_ebitda_disp').textContent = ebitda > 0 ? `${evEbitda} 倍` : '— 倍';

  // Bar chart
  const vals = [m, n, d];
  const labels = ['マルチプル法', '純資産法', 'DCF法'];
  const colors = ['#1a56db', '#0e9f6e', '#e3a008'];
  const maxV = Math.max(...vals.filter(v => !isNaN(v) && v > 0), 1);
  const chart = $('sum_chart');
  chart.innerHTML = vals.map((v, i) => {
    const pct = Math.max((v / maxV) * 100, 2);
    return `<div class="bar-group">
      <div class="bar-val">${fmtNum(Math.round(v))}</div>
      <div class="bar-outer">
        <div class="bar" style="height:${pct}%; background:${colors[i]};"></div>
      </div>
      <div class="bar-label">${labels[i]}</div>
    </div>`;
  }).join('');

  // Recommendation
  const max = Math.max(m, n, d);
  const min = Math.min(m, n, d);
  const spread = max - min;
  const spreadPct = max > 0 ? Math.round((spread / max) * 100) : 0;
  const ebitdaStr = ebitda > 0 ? `調整EBITDA ${fmtNum(Math.round(ebitda))}万円（${margin}%）、` : '';
  const netDebtStr = isNetCash
    ? `ネットキャッシュ ${fmtNum(Math.abs(Math.round(netDebt)))}万円（財務良好）。`
    : `純有利子負債 ${fmtNum(Math.round(netDebt))}万円（EV/EBITDA ${evEbitda}倍）。`;
  let comment = `${ebitdaStr}${netDebtStr} `;
  if (spreadPct < 20) {
    comment += `3手法の評価額が収束しており（乖離率 ${spreadPct}%）、加重平均 ${fmtNum(Math.round(weighted))} 万円前後を交渉基準とすることを推奨します。`;
  } else if (spreadPct < 50) {
    comment += `3手法間に ${spreadPct}% の乖離があります。マルチプル法を市場参照として重視しつつ、DCF法で将来性を加味する加重平均アプローチが有効です。交渉レンジ ${fmtNum(Math.round(weighted*0.9))}〜${fmtNum(Math.round(weighted*1.1))} 万円を目安にしてください。`;
  } else {
    comment += `3手法間の乖離が大きく（${spreadPct}%）、評価前提の再確認を推奨します。純資産が低い場合はのれん倍率を見直し、DCFが大きく乖離する場合はWACC・成長率の妥当性を再検討してください。`;
  }
  $('sum_recommendation').textContent = comment;
}

function updateWeights(changedId) {
  const ids = ['w_m', 'w_n', 'w_d'];
  const changed = ids.indexOf(changedId);
  const values = ids.map(id => parseInt($(id).value));
  const changedVal = values[changed];
  const others = ids.filter((_, i) => i !== changed);
  const remaining = 100 - changedVal;
  const otherSum = values.filter((_, i) => i !== changed).reduce((a, b) => a + b, 0);

  if (otherSum > 0) {
    others.forEach((id, i) => {
      const idx = ids.indexOf(id);
      const newVal = Math.round(values[idx] / otherSum * remaining);
      $(id).value = newVal;
    });
  } else {
    others.forEach(id => $(id).value = Math.round(remaining / 2));
  }

  ids.forEach(id => $(`${id}_val`).textContent = $(id).value);
  updateSummary();
}

