// ── 単位自動検出 ──────────────────────────────────────────────
function autoDetectUnit(text) {
  const sel = $('unit-select');
  if (/単位[：:\s]*百万円/.test(text))     { sel.value = '100';    sel.options[0].text = '百万円（自動検出）'; }
  else if (/単位[：:\s]*万円/.test(text))  { sel.value = '1';      sel.options[0].text = '万円（自動検出）'; }
  else if (/単位[：:\s]*千円/.test(text))  { sel.value = '0.1';    sel.options[0].text = '千円（自動検出）'; }
  else if (/単位[：:\s]*円/.test(text))    { sel.value = '0.0001'; sel.options[0].text = '円（自動検出）'; }
  else                                     { sel.value = '0.1';    sel.options[0].text = '千円（推定）'; }
  $('unit-row').style.display = 'flex';
}

// ── 財務数値パース（医療法人・企業概要書対応）────────────────
function parseAndShow(text, multiplier) {
  const results = {};

  // 行に分割。空行除去・トリム
  const lines = text.split(/[\r\n]+/).map(l => l.trim()).filter(l => l.length > 0);

  // ★ 各行の「スペース除去版」を用意 → 文字間スペースのある PDF に対応
  //    例: "現 金 ・ 預 金" → "現金・預金"
  const normLines = lines.map(l => l.replace(/[\s　]+/g, ''));

  for (const field of EXTRACT_FIELDS) {
    const allCands = [];
    const seenKeys = new Set(); // "rawNum_lineIdx" で重複排除（値が偶然一致する別行を区別）

    for (const keyword of field.patterns) {
      // キーワード自身もスペース除去して照合
      const normKeyword = keyword.replace(/[\s　]+/g, '');

      for (let li = 0; li < lines.length; li++) {
        if (!normLines[li].includes(normKeyword)) continue;

        // キーワード行から最大6行を結合（値が次行以降にある場合に対応）
        const ctxLines = lines.slice(li, Math.min(li + 6, lines.length));
        const normCtxLines = normLines.slice(li, Math.min(li + 6, normLines.length));
        const normCtx = normCtxLines.join(' ');

        // 正規化コンテキスト内でキーワード以降のテキストを取得
        const normKwEnd = normCtx.indexOf(normKeyword) + normKeyword.length;
        const afterKw = normCtx.substring(normKwEnd);

        // ★ 数値パターン改善
        //   ・カンマ区切り: 1〜3桁 + (,3桁)+ 　例: 5,200 / 1,234,567
        //   ・連続数字: 4桁以上（カンマなし）　例: 5200 / 12000
        //   ・パーセント表記（全角/半角）は除外
        const cleaned = afterKw
          .replace(/[\d,.]+[%％]/g, 'PCT') // パーセント前の数字を除外
          .replace(/\.\d+/g, '');          // 小数部分を除去（整数のみ対象）

        const numRe = /([▲△\-])?\s*([\d]{1,3}(?:,[\d]{3})+|[\d]{4,})/g;
        let m;
        const lineNums = [];

        while ((m = numRe.exec(cleaned)) !== null) {
          const isNeg  = !!(m[1]);
          const rawStr = m[2].replace(/,/g, '');
          const rawNum = parseInt(rawStr);

          // ★ 合理性チェック緩和：10以上（千円単位で1万円相当） 〜 9,999億
          if (rawNum < 10 || rawNum > 9999999999) continue;

          const manVal = Math.round(rawNum * multiplier);

          // 同一行・同一値の重複を排除
          const dedupeKey = `${rawNum}_${li}`;
          if (seenKeys.has(dedupeKey)) continue;
          seenKeys.add(dedupeKey);

          lineNums.push({ raw: m[2], value: isNeg ? -manVal : manVal, keyword });
        }

        // 3期並列表（2つ以上の数字がある行）→ 最後が最新期
        lineNums.forEach((n, idx) => {
          allCands.push({
            ...n,
            recommended: lineNums.length >= 2 && idx === lineNums.length - 1,
          });
        });
      }
    }

    // 推奨候補（直近期）を先頭に
    const sorted = [
      ...allCands.filter(c => c.recommended),
      ...allCands.filter(c => !c.recommended),
    ];
    const best = sorted[0];

    results[field.key] = {
      candidates: sorted,
      value:      best ? Math.abs(best.value) : 0,
      raw:        best ? best.raw : '—',
      found:      sorted.length > 0,
      keyword:    best ? best.keyword : '',
    };
  }

  // 純有利子負債はメインアプリがn_loan/n_cashから自動計算するため、ここでの計算は不要
  extractedData = results;
  renderExtractTable(results);
}

