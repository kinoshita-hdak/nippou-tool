            <div class="breakdown-row"><span>− 新役員報酬（控除）</span><span class="val neg" id="m_exec_new_disp">—</span></div>
            <div class="breakdown-row total"><span>調整EBITDA</span><span class="val" id="m_ebitda_disp">—</span></div>
            <div class="breakdown-row"><span>× 倍率</span><span class="val" id="m_mult1_disp">—</span></div>
            <div class="breakdown-row"><span>EV（事業価値）</span><span class="val pos" id="m_ev1_disp">—</span></div>
            <div class="breakdown-row"><span>− 純有利子負債</span><span class="val neg" id="m_debt1_disp">—</span></div>
            <div class="breakdown-row total"><span>株式価値（買収価格目安）</span><span class="val" id="m_equity1_disp">—</span></div>
          </div>
          <div class="result-box">
