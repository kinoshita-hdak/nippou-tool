  const wrap = $('progress-wrap');
  const fill = $('progress-fill');
  const pmsg = $('progress-msg');
  wrap.style.display = 'block';
  fill.style.width   = pct + '%';
  pmsg.textContent   = msg;
  if (pct >= 100 || pct === 0) setTimeout(() => { wrap.style.display = 'none'; }, 2000);
}

function escHtml(str) {
  return String(str).replace(/&/g,'&amp;').replace(/</g,'&lt;').replace(/>/g,'&gt;');
}

// ══════════════════════════════════════════════════════════════
// 💾 保存・読込機能
// ══════════════════════════════════════════════════════════════

const SAVE_STORAGE_KEY = 'ma_valuation_saves';
const SAVE_MAX = 20;

// 保存対象フィールド定義
const SAVE_FIELDS = [
  // マルチプル法（d_revenue/d_ebit/d_daはマルチプル法と連動のため不要）
  'm_revenue','m_ebit','m_da','m_exec_current','m_exec_new',
  'm_ebitda_mult','m_rev_mult',
  // 純資産法 ── 流動資産
  'n_cash','n_ar','n_inventory','n_other_current',
  // 純資産法 ── 固定資産
  'n_equipment','n_interior','n_lease','n_deposit','n_other_asset',
  // 純資産法 ── 流動負債
  'n_short_loan','n_ap','n_accrued','n_other_current_liab',
  // 純資産法 ── 固定負債
  'n_long_loan','n_lease_liab','n_other_liab',
  // 純資産法 ── 調整・のれん
  'n_equip_adj','n_gw_mult',
  // DCF法（売上・営業利益・減価償却はm_*から自動連動）
  'd_tax','d_capex','d_wc','d_growth','d_wacc','d_terminal','d_years',
  // 総合評価ウェイト
  'w_m','w_n','w_d',
];

// ── モーダル制御 ──────────────────────────────────────────────
function openSaveModal() {
  updateSavePreview();
  renderSaveList();
  $('save-modal').classList.add('open');
}
function closeSaveModal() {
  $('save-modal').classList.remove('open');
}
function switchSaveTab(tab) {
  const tabs = ['save','load','io'];
  document.querySelectorAll('.save-tab-btn').forEach((b, i) =>
    b.classList.toggle('active', tabs[i] === tab));
  document.querySelectorAll('.save-panel').forEach((p, i) =>
    p.classList.toggle('active', tabs[i] === tab));
  if (tab === 'load') renderSaveList();
  if (tab === 'save') updateSavePreview();
}

// ── 現在値を収集 ──────────────────────────────────────────────
function collectCurrentValues() {
  const data = {};
  for (const id of SAVE_FIELDS) {
    const el = $(id);
    if (el) data[id] = el.value;
  }
  return data;
}

// ── 値をフォームに適用 ────────────────────────────────────────
function applyValues(data) {
  for (const id of SAVE_FIELDS) {
    const el = $(id);
    if (el && data[id] !== undefined) el.value = data[id];
  }
  // スライダーラベル更新
  const sliders = [
    ['m_ebitda_mult','m_ebitda_mult_val'],
    ['m_rev_mult','m_rev_mult_val'],
    ['n_gw_mult','n_gw_mult_val'],
    ['d_tax','d_tax_val'],
    ['d_growth','d_growth_val'],
    ['d_wacc','d_wacc_val'],
    ['d_terminal','d_terminal_val'],
    ['w_m','w_m_val'],['w_n','w_n_val'],['w_d','w_d_val'],
  ];
  sliders.forEach(([sid, lid]) => { if ($(sid) && $(lid)) updateSlider(sid, lid); });
  // 再計算
  _recalcInProgress = true;
  calcMultiple();
  calcNetAsset();
  calcDCF();
  _recalcInProgress = false;
}

// ── 保存プレビュー更新 ────────────────────────────────────────
function updateSavePreview() {
  const ebitda = val('m_ebitda_disp') !== undefined
    ? (val('m_ebit') + val('m_da') + val('m_exec_current') - val('m_exec_new'))
    : 0;
  const revenue = val('m_revenue');
  const netAsset = state.netasset.value;
  const dcfVal   = state.dcf.value;
  $('save-preview').innerHTML = `
    <div style="display:grid;grid-template-columns:1fr 1fr 1fr;gap:8px;">
      <div style="background:#eff6ff;border-radius:6px;padding:8px;text-align:center;">
        <div style="font-size:10px;color:var(--text-muted);">売上高</div>
        <div style="font-weight:700;color:var(--primary);">${fmtNum(revenue)} 万円</div>
      </div>
      <div style="background:#ecfdf5;border-radius:6px;padding:8px;text-align:center;">
        <div style="font-size:10px;color:var(--text-muted);">調整EBITDA</div>
        <div style="font-weight:700;color:#065f46;">${fmtNum(Math.round(ebitda))} 万円</div>
      </div>
      <div style="background:#fffbeb;border-radius:6px;padding:8px;text-align:center;">
        <div style="font-size:10px;color:var(--text-muted);">マルチプル中央値</div>
        <div style="font-weight:700;color:#92400e;">${fmtNum(Math.round((state.multiple.ebitda + state.multiple.rev)/2))} 万円</div>
      </div>
      <div style="background:#ecfdf5;border-radius:6px;padding:8px;text-align:center;">
        <div style="font-size:10px;color:var(--text-muted);">純資産法</div>
        <div style="font-weight:700;color:#065f46;">${fmtNum(Math.round(netAsset))} 万円</div>
      </div>
      <div style="background:#fffbeb;border-radius:6px;padding:8px;text-align:center;">
        <div style="font-size:10px;color:var(--text-muted);">DCF法</div>
        <div style="font-weight:700;color:#92400e;">${fmtNum(Math.round(dcfVal))} 万円</div>
      </div>
      <div style="background:#dbeafe;border-radius:6px;padding:8px;text-align:center;">
        <div style="font-size:10px;color:var(--primary);">借入金 − 現預金</div>
        <div style="font-weight:700;color:var(--primary-dark);">${fmtNum(val('n_loan') - val('n_cash'))} 万円</div>
      </div>
    </div>
  `;
}

// ── localStorage 操作 ─────────────────────────────────────────
function loadSaves() {
  try { return JSON.parse(localStorage.getItem(SAVE_STORAGE_KEY) || '[]'); }
  catch { return []; }
}
function storeSaves(list) {
  localStorage.setItem(SAVE_STORAGE_KEY, JSON.stringify(list));
}

// ── 保存実行 ──────────────────────────────────────────────────
function doSave() {
  const nameInput = $('save-name-input');
  const name = nameInput.value.trim();
  if (!name) { nameInput.focus(); nameInput.style.borderColor='#ef4444'; return; }
  nameInput.style.borderColor = '';

  const saves = loadSaves();
  if (saves.length >= SAVE_MAX) {
    alert(`保存できるのは最大${SAVE_MAX}件までです。\n不要なデータを削除してください。`); return;
  }

  const entry = {
    id:      Date.now(),
    name,
    savedAt: new Date().toLocaleString('ja-JP'),
    data:    collectCurrentValues(),
    summary: {
      revenue:   val('m_revenue'),
      ebitda:    Math.round(val('m_ebit') + val('m_da') + val('m_exec_current') - val('m_exec_new')),
      multiple:  Math.round((state.multiple.ebitda + state.multiple.rev) / 2),
      netasset:  Math.round(state.netasset.value),
      dcf:       Math.round(state.dcf.value),
    },
  };

  saves.unshift(entry); // 最新を先頭に
  storeSaves(saves);
  nameInput.value = '';

  showToast(`💾 「${name}」を保存しました`);
  renderSaveList();
  switchSaveTab('load'); // 保存後は読込リストを表示
}

// ── 読込リスト描画 ────────────────────────────────────────────
function renderSaveList() {
  const saves = loadSaves();
  const list  = $('save-list');
  $('save-count-disp').textContent = `${saves.length} / ${SAVE_MAX} 件`;

  if (saves.length === 0) {
    list.innerHTML = `
      <div class="save-empty">
        <div class="se-icon">📭</div>
        <div>保存済みデータがありません</div>
        <div style="font-size:11px;margin-top:4px;">「保存」タブから現在の入力値を保存できます</div>
      </div>`;
    return;
  }

  list.innerHTML = saves.map(entry => `
    <div class="save-item" onclick="doLoad(${entry.id})">
      <div class="si-icon">📋</div>
      <div class="si-info">
        <div class="si-name">${escHtml(entry.name)}</div>
        <div class="si-date">💾 ${entry.savedAt}</div>
        <div class="si-preview">
          売上 ${fmtNum(entry.summary.revenue)}万 ／
          EBITDA ${fmtNum(entry.summary.ebitda)}万 ／
          マルチプル ${fmtNum(entry.summary.multiple)}万 ／
          純資産 ${fmtNum(entry.summary.netasset)}万 ／
          DCF ${fmtNum(entry.summary.dcf)}万
        </div>
      </div>
      <button class="si-del" onclick="event.stopPropagation(); doDelete(${entry.id})">🗑 削除</button>
    </div>
  `).join('');
}

// ── 読込実行 ──────────────────────────────────────────────────
function doLoad(id) {
  const saves = loadSaves();
  const entry = saves.find(s => s.id === id);
  if (!entry) return;
  if (!confirm(`「${entry.name}」を読み込みます。\n現在の入力値は上書きされます。よろしいですか？`)) return;
  applyValues(entry.data);
  closeSaveModal();
  showToast(`📂 「${entry.name}」を読み込みました`);
}

// ── 削除実行 ──────────────────────────────────────────────────
function doDelete(id) {
  const saves = loadSaves();
  const entry = saves.find(s => s.id === id);
  if (!entry) return;
  if (!confirm(`「${entry.name}」を削除しますか？`)) return;
  storeSaves(saves.filter(s => s.id !== id));
  renderSaveList();
}

// ── JSONエクスポート ───────────────────────────────────────────
function doExport() {
  const nameInput = $('export-name-input');
  const name = nameInput.value.trim() || 'MAバリュエーション';
  const exportData = {
    appVersion: '1.0',
    exportedAt: new Date().toLocaleString('ja-JP'),
    name,
    data: collectCurrentValues(),
    summary: {
      revenue:  val('m_revenue'),
      ebitda:   Math.round(val('m_ebit') + val('m_da') + val('m_exec_current') - val('m_exec_new')),
      multiple: Math.round((state.multiple.ebitda + state.multiple.rev) / 2),
      netasset: Math.round(state.netasset.value),
      dcf:      Math.round(state.dcf.value),
    },
  };
  const blob = new Blob([JSON.stringify(exportData, null, 2)], { type: 'application/json' });
  const url  = URL.createObjectURL(blob);
  const a    = document.createElement('a');
  a.href     = url;
  a.download = `${name}_${new Date().toLocaleDateString('ja-JP').replace(/\//g,'-')}.json`;
  a.click();
  URL.revokeObjectURL(url);
  showToast(`📥 「${name}」をダウンロードしました`);
}

// ── JSONインポート ────────────────────────────────────────────
function onImportFile(e) {
  const file = e.target.files[0];
  if (file) readImportFile(file);
}
function onImportDrop(e) {
  e.preventDefault();
  $('import-drop-zone').style.background = '#eff6ff';
  const file = e.dataTransfer.files[0];
  if (file) readImportFile(file);
}
function readImportFile(file) {
  if (!file.name.toLowerCase().endsWith('.json')) {
    alert('JSONファイルを選択してください'); return;
  }
  const reader = new FileReader();
  reader.onload = (e) => {
    try {
      const importData = JSON.parse(e.target.result);
      if (!importData.data) throw new Error('データ形式が正しくありません');
      const name = importData.name || file.name;
      if (!confirm(`「${name}」をインポートします。\n現在の入力値は上書きされます。よろしいですか？`)) return;
      applyValues(importData.data);
      closeSaveModal();
      showToast(`📂 「${name}」をインポートしました`);
    } catch (err) {
      alert(`インポートエラー: ${err.message}`);
    }
  };
  reader.readAsText(file, 'utf-8');
}

// ── トースト通知 ──────────────────────────────────────────────
function showToast(msg, color = '#059669') {
  const el = document.createElement('div');
  el.style.cssText = `
    position:fixed; top:24px; left:50%; transform:translateX(-50%);
    background:${color}; color:#fff; padding:12px 28px;
    border-radius:10px; font-weight:700; font-size:14px;
    z-index:9999; box-shadow:0 4px 16px rgba(0,0,0,.25);
    animation: fadeInDown .3s ease;
  `;
  el.textContent = msg;
  document.body.appendChild(el);
  setTimeout(() => { el.style.opacity='0'; el.style.transition='opacity .4s'; }, 2500);
  setTimeout(() => el.remove(), 3000);
}
</script>
