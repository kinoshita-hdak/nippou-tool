// ── 抽出結果テーブル描画 ─────────────────────────────────────
function renderExtractTable(results) {
  const tbody  = $('extract-tbody');
  const foundN = Object.values(results).filter(r => r.found).length;
  $('found-summary').textContent = `${foundN} / ${EXTRACT_FIELDS.length} 項目検出`;
  $('extract-result').style.display = 'block';
  $('apply-btn').disabled = (foundN === 0);

  tbody.innerHTML = EXTRACT_FIELDS.map(field => {
    const r       = results[field.key];
    const checked = r.found ? 'checked' : '';
    const trClass = r.found ? '' : 'not-found';
    const cnt     = r.candidates ? r.candidates.length : 0;
    const isComp  = field.computed;
    const badge   = isComp
      ? `<span class="found-badge" style="background:#e0e7ff;color:#3730a3;">🔢 自動計算</span>`
      : r.found
        ? `<span class="found-badge ok">検出${cnt > 1 ? ` (${cnt}件)` : ''}</span>`
        : `<span class="found-badge ng">未検出</span>`;
    const targets = field.fieldNames.map(n =>
      `<span class="targets">${n}</span>`).join('<br>');

    // 複数候補 → ドロップダウン。単数 → 原文テキスト表示
    let candHtml = '';
    if (isComp && r.found) {
      // 計算式を表示
      const lv = extractedData['loan']  ? Math.abs(extractedData['loan'].value)  : 0;
      const cv = extractedData['cash']  ? Math.abs(extractedData['cash'].value)  : 0;
      const sign = r.value >= 0 ? '（有利子負債超過）' : '（ネットキャッシュ）';
      candHtml = `<span style="font-size:11px;color:#3730a3;">
        借入金 ${lv.toLocaleString()} − 現預金 ${cv.toLocaleString()} = <strong>${r.value.toLocaleString()}</strong> 万円 ${sign}
      </span>`;
    } else if (cnt > 1) {
      const opts = r.candidates.map((c, i) => {
        const label = `${Math.abs(c.value).toLocaleString()} 万円（原文: ${c.raw}）${c.recommended ? ' ★直近期' : ''}`;
        return `<option value="${c.value}" ${i === 0 ? 'selected' : ''}>${label}</option>`;
      }).join('');
      candHtml = `<select class="cand-select"
        onchange="selectCandidate('${field.key}', this.value)">${opts}</select>`;
    } else if (r.found) {
      candHtml = `<span style="font-size:10px;color:var(--text-muted);">原文: ${escHtml(r.raw)}</span>`;
    }

    return `<tr class="${trClass}">
      <td>
        <strong>${field.label}</strong>
        ${field.note ? `<br><span style="font-size:10px;color:var(--text-muted);">${field.note}</span>` : ''}
      </td>
      <td>${badge}<br>${candHtml}</td>
      <td>
        <input class="val-input" type="number" id="ext_${field.key}"
          value="${r.found || isComp ? r.value : ''}" placeholder="${(r.found || isComp) ? '' : '手入力（万円）'}">
        <span style="font-size:10px;color:var(--text-muted);"> 万円</span>
        ${isComp && r.value < 0 ? `<div style="font-size:10px;color:#059669;font-weight:700;">※マイナス＝ネットキャッシュ（EV加算）</div>` : ''}
      </td>
      <td>${targets}</td>
      <td style="text-align:center;">
        <input type="checkbox" id="chk_${field.key}" ${checked}
          style="width:16px;height:16px;cursor:pointer;">
      </td>
    </tr>`;
  }).join('');
}

// ── フィールドに適用 ──────────────────────────────────────────
function applyExtractedData() {
  let applied = 0;
  for (const field of EXTRACT_FIELDS) {
    const chk = $(`chk_${field.key}`);
    if (!chk || !chk.checked) continue;
    const value = parseFloat($(`ext_${field.key}`).value) || 0;
    for (const inputId of field.inputIds) {
      const el = $(inputId);
      if (el) { el.value = value; applied++; }
    }
  }
  // 再計算
  calcMultiple();
  calcNetAsset();
  calcDCF();
  closeUploadModal();
  // 完了通知
  const notice = document.createElement('div');
  notice.style.cssText = 'position:fixed;top:20px;left:50%;transform:translateX(-50%);background:#059669;color:#fff;padding:12px 24px;border-radius:10px;font-weight:700;font-size:14px;z-index:9999;box-shadow:0 4px 12px rgba(0,0,0,.2);';
  notice.textContent   = `✅ ${applied} フィールドに決算数値を適用しました`;
  document.body.appendChild(notice);
  setTimeout(() => notice.remove(), 3500);
}

